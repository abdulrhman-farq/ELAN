# Optional — real photos from a public Supabase Storage "media" bucket.
# When set, images load from here (<name>.jpg); otherwise bundled SVG art is used.
# NEXT_PUBLIC_ELAN_MEDIA_BASE=https://<your-ref>.supabase.co/storage/v1/object/public/media

# Demo/showcase mode. OFF by default and FORCED off in production.
# Only "true" in a non-production environment enables mock data + auth bypass.
NEXT_PUBLIC_ELAN_DEMO=false

# Public site URL (used for auth redirect / magic-link callback).
NEXT_PUBLIC_SITE_URL=https://elan-rosy.vercel.app

# Optional — real providers switch on automatically when these exist.
# MOYASAR_SECRET_KEY=
# MOYASAR_PUBLISHABLE_KEY=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# RESEND_API_KEY=
# RESEND_FROM=ÉLAN <hello@yourdomain.com>
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SUPABASE_SERVICE_ROLE_KEY=
