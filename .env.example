# Zero-config defaults — point at the seeded ELAN demo project.
# The anon key is public-safe (RLS enforced). Swap for your own to go live.
NEXT_PUBLIC_SUPABASE_URL=https://knldyssbwygrkxamttez.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtubGR5c3Nid3lncmt4YW10dGV6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE4NTg4MjIsImV4cCI6MjA5NzQzNDgyMn0.0Ol4bTSVAevhFNGmII13bAKKtdztnO_F4wd62ZzOnK8

# Optional — real photos from a public Supabase Storage "media" bucket.
# When set, images load from here (<name>.jpg); otherwise bundled SVG art is used.
# NEXT_PUBLIC_ELAN_MEDIA_BASE=https://<your-ref>.supabase.co/storage/v1/object/public/media

# Demo/showcase mode. OFF by default and FORCED off in production.
# Only "true" in a non-production environment enables mock data + auth bypass.
NEXT_PUBLIC_ELAN_DEMO=false

# Public site URL (used for auth redirect / magic-link callback).
NEXT_PUBLIC_SITE_URL=https://elan-rosy.vercel.app

# Optional — real providers switch on automatically when these exist.
# MOYASAR_SECRET_KEY=
# MOYASAR_PUBLISHABLE_KEY=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# SENTRY_DSN=

# =============================================================================
# Launch hardening (all OPTIONAL for local dev — the app runs zero-config).
# Anything below is inert/feature-flagged when unset. Leave secret values empty.
# RULE: server-only secrets must NEVER carry a NEXT_PUBLIC_ prefix — that would
# ship them to the browser bundle. Only NEXT_PUBLIC_* vars are client-exposed.
# =============================================================================

# --- Cron / background jobs (server-only) ---
# Shared secret that authorizes /api/cron/notifications. The cron caller must
# send this; requests without a matching value are rejected.
CRON_SECRET=

# --- Supabase service role (server-only — privileged, bypasses RLS) ---
# Used by the payment webhook handler and the notification worker. NEVER expose
# to the client and NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- Error tracking (Sentry — entirely inert if unset) ---
# Server-side DSN.
SENTRY_DSN=
# Client/browser DSN (safe to expose).
NEXT_PUBLIC_SENTRY_DSN=
# Optional — only needed to upload source maps during the build.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Login CAPTCHA (hCaptcha — widget is inert if unset) ---
# Public site key for the hCaptcha widget on the login form.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

# --- Contact page (public; sensible defaults already exist in code) ---
# Override these to point at the live studio's real contact details.
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_WHATSAPP=
NEXT_PUBLIC_STUDIO_ADDRESS_AR=
NEXT_PUBLIC_STUDIO_ADDRESS_EN=

# --- Integration tests (STAGING ONLY) ---
# Enable the conditional Supabase integration test suite
# (src/lib/__tests__/integration.test.ts). It stays skipped unless these are
# set. NEVER point these at production — the suite writes/reads real data.
SUPABASE_TEST_URL=
SUPABASE_TEST_ANON_KEY=
SUPABASE_TEST_SERVICE_ROLE_KEY=
